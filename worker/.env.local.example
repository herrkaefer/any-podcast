# Worker environment variables
NODE_ENV=development

# Worker URLs
PODCAST_WORKER_URL=http://localhost:8787
PODCAST_R2_BUCKET_URL=http://localhost:8787/static

# Podcast identity
PODCAST_ID=any-podcast

# Gemini
GEMINI_API_KEY=your_gemini_key

# MiniMax (optional, for text generation)
# MINIMAX_API_KEY=your_minimax_key

# OpenAI (optional)
# OPENAI_API_KEY=your_openai_key

# Jina (optional)
# JINA_KEY=your_jina_key

# Gmail newsletter (optional)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_USER_EMAIL=

# MiniMax TTS (optional)
# MINIMAX_TTS_GROUP_ID=
# MINIMAX_TTS_API_KEY=

# Murf TTS (optional)
# MURF_API_KEY=

# Admin
ADMIN_TOKEN=

TRIGGER_TOKEN=

# Runtime behavior such as AI provider/model/base URL, workflow test settings,
# sources, prompts, and TTS options is configured in Admin, not via env.
