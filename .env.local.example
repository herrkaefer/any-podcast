# Next.js app environment variables
NODE_ENV=development
NEXT_STATIC_HOST=http://localhost:3000/static
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Podcast identity
PODCAST_ID=any-podcast

# Admin console
ADMIN_TOKEN=

# Optional for production web -> worker trigger routing
# Local development trigger requests default to http://localhost:8787
# PODCAST_WORKER_URL=https://your-worker.example.workers.dev
# TRIGGER_TOKEN=
